rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email == 'minhpham.tst@gmail.com' || request.auth.token.email == 'hongquannguyen.1206@gmail.com' || request.auth.token.email == 'minhpham.tst+admin@gmail.com' || request.auth.token.email == 'hongquannguyen.1206+admin@gmail.com' || request.auth.token.email == 'admin@smartdata.vn') ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email != null && exists(/databases/$(database)/documents/admins/$(request.auth.token.email)))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidPackage(data) {
      return data.keys().hasAll(['name', 'price', 'categoryId', 'registrationSyntax', 'network', 'registrationNumber']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.network in ['viettel', 'vinaphone', 'mobifone'] &&
             data.price is number && data.price >= 0 &&
             data.categoryId is string && data.categoryId.size() <= 128 &&
             data.registrationSyntax is string && data.registrationSyntax.size() > 0 && data.registrationSyntax.size() <= 100 &&
             data.registrationNumber is string && data.registrationNumber.size() > 0 && data.registrationNumber.size() <= 100 &&
             (!('dataAmount' in data) || (data.dataAmount is string && data.dataAmount.size() <= 500)) &&
             (!('voiceMinutes' in data) || (data.voiceMinutes is string && data.voiceMinutes.size() <= 500)) &&
             (!('description' in data) || (data.description is string && data.description.size() <= 10000)) &&
             (!('longDescription' in data) || (data.longDescription is string && data.longDescription.size() <= 100000)) &&
             (!('featured' in data) || data.featured is bool) &&
             (!('active' in data) || data.active is bool) &&
             (!('order' in data) || data.order is number) &&
             (!('smsAmount' in data) || (data.smsAmount is string && data.smsAmount.size() <= 500)) &&
             (!('validity' in data) || (data.validity is string && data.validity.size() <= 500)) &&
             (!('badge' in data) || (data.badge is string && data.badge.size() <= 200)) &&
             (!('highlightPromo' in data) || (data.highlightPromo is string && data.highlightPromo.size() <= 2000)) &&
             (!('registerButtonText' in data) || (data.registerButtonText is string && data.registerButtonText.size() <= 200)) &&
             (!('isSim' in data) || data.isSim is bool);
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'slug']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.slug is string && data.slug.size() > 0 && data.slug.size() <= 100 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 1000)) &&
             (!('active' in data) || data.active is bool) &&
             (!('order' in data) || data.order is number);
    }

    function isValidConfig(data) {
      return data.size() <= 50; // Simple size check, structure managed by UI
    }

    // --- Collections ---

    match /packages/{packageId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(packageId) && isValidPackage(incoming());
      allow update: if isAdmin() && isValidPackage(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly([
          'name', 'price', 'dataAmount', 'voiceMinutes', 'smsAmount', 'validity', 'network', 'registrationNumber',
          'description', 'longDescription', 'categoryId', 'registrationSyntax', 'featured', 'active', 'updatedAt', 'createdAt', 'badge', 'highlightPromo', 'registerButtonText', 'order', 'isSim'
        ])
      );
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(categoryId) && isValidCategory(incoming());
      allow update: if isAdmin() && isValidCategory(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly([
          'name', 'slug', 'description', 'active', 'order'
        ])
      );
      allow delete: if isAdmin();
    }

    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin() && isValidConfig(incoming());
    }

    match /menus/{menuId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admins/{userId} {
      allow read: if isAdmin();
      allow write: if isSignedIn() && (request.auth.token.email == 'minhpham.tst@gmail.com' || request.auth.token.email == 'hongquannguyen.1206@gmail.com' || request.auth.token.email == 'minhpham.tst+admin@gmail.com' || request.auth.token.email == 'hongquannguyen.1206+admin@gmail.com' || request.auth.token.email == 'admin@smartdata.vn');
    }
  }
}
